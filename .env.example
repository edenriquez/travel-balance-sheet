# Database (local: use docker-compose postgres)
DATABASE_URL=postgresql+asyncpg://app:secret@localhost:5432/travel_balance

# App
ENVIRONMENT=local
APP_VERSION=1.0

# Auth (set in production)
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
JWT_EXP_MINUTES=60

# Frontend URL (for invite links in set-password email)
FRONTEND_URL=http://localhost:5173

# CORS (comma-separated origins, or empty)
CORS_ORIGINS=

# WhatsApp (Kapso)
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=
KAPSO_WEBHOOK_SECRET=

# MinIO (S3-compatible storage for receipt images)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=evidence
MINIO_USE_SSL=false
